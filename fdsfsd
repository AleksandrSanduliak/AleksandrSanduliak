*{
    background-color: white; /* background color for*/

}

header{
   display: flex;
    block-size: 100px;
}
.googlefamily{
    font-family: "Roboto", sans-serif;
    font-variant: small-caps;
}
.sansserife{
    white-space: wrap;
    font-family: "Courier New", Courier, monospace;
}

.fontfamilyz{
    font-family: "Trebuchet MS", Helvetica, sans-serif;;
white-space: wrap;
font-style: oblique;

}
    
.first{
    background-color: red; /* red block */
    width: 100px;
    outline: 3px solid rgb(107, 0, 0);
    border: 2px dashed black;
    opacity: 0.9;
   max-height: 400px;
   min-height: 45px;
   max-width: 400px;
   min-width: 50px;
   margin-right: 20px;
   margin-left: 5px;
   margin-top: 5px;
   outline-offset: 5px;
   text-align: justify;
   color: rgb(131, 34, 34);
   vertical-align: middle;
   
   
}

.two{
    background-color: red; /* red block */
    width: 100px;
    border: 2px dashed black;
    opacity: 0.7;

}

.three{
    background-color: red; /* red block */
    width: 100px;
    border: dotted black;
    border-bottom-style: solid;
    opacity: 0.5;   
    min-width: 50px;
}

.four{
    background-color: red; /* red block */
    width: 100px;
    border: dotted black;  
    opacity: 0.2;
}

.five{
    background-color: blue; /* red block */
    border-left: 2px solid black;
    width: 100px;
    block-size: 20px;
}

.imgtop{
    vertical-align: middle;
}

.aline{
    text-decoration: none;
}
.texttrans{
    text-transform: capitalize;
}

p{
    line-height: 0.8;
}

a:link{
    text-decoration: none;
    border: 3px lightblue solid; 
    color: black;
    padding-left: 2px;
    opacity: 1;
}

a:hover, a:active{
    text-decoration: none;
    color:white;
    background-color: lightblue;
    border: 3px lightblue solid;
}
ul{
list-style-type: none;
padding: 0;
margin: 0;
list-style-position: inside;
}

table, th, td{
    border: 1px solid black;
    border-collapse: collapse;
    text-align: center;
}
table{
    max-width: 80%;
    min-width: 50%;
    max-height: 50px;
    min-height: 10px;
}

th, td{
    padding: 20px;

}

th{
    height: 30px;
}
td:hover{
background-color: grey;
}
th, tr:nth-child(even){
background-color: honeydew;
}

.overflow{
    overflow-x:auto;
}
